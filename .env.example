# FitScan Backend — copy this to .env and fill in your values

# Server
APP_HOST=localhost
APP_PORT=8000

# Model paths (run download_models.py to get these)
YOLO_MODEL_PATH=models/yolov8n.pt
MEDIAPIPE_MODEL_PATH=models/pose_landmarker_full.task

# Pipeline settings
DETECTION_CONFIDENCE=0.6
LANDMARK_VISIBILITY_THRESHOLD=0.6
FRAME_SKIP_INTERVAL=1.5

# Privacy (keep false in production)
STORE_IMAGES=false
